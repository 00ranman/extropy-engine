# ═══════════════════════════════════════════════════════════════════════════════
#  EXTROPY ENGINE — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL
DATABASE_URL=postgresql://extropy:extropy_dev@localhost:5432/extropy_engine

# Redis (event bus)
REDIS_URL=redis://localhost:6379

# Service URLs (for inter-service HTTP calls)
EPISTEMOLOGY_URL=http://localhost:4001
SIGNALFLOW_URL=http://localhost:4002
LOOP_LEDGER_URL=http://localhost:4003
REPUTATION_URL=http://localhost:4004
XP_MINT_URL=http://localhost:4005

# Logging
LOG_LEVEL=debug

# ─── HomeFlow Family Pilot ──────────────────────────────────────────────────
# Used by `pnpm --filter @extropy/homeflow run dev` so the family can sign in
# with Google from their own laptops. See FAMILY_PILOT.md for the full setup.

# Port the homeflow server listens on. Default 4015 in code; the pilot uses
# 4001 so each family member can hit http://<lan-ip>:4001 directly.
PORT=4001

# Public base URL the browser connects to. Used to build the Google OAuth
# callback URL. Set this to your LAN IP plus port for local family use.
BASE_URL=http://localhost:4001

# Sign cookies for the express-session store. Generate with
#   openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Set this to 1 only when serving the pilot over HTTPS, e.g. via Cloudflare
# Tunnel. On HTTP only LAN it must stay unset.
# SECURE_COOKIES=1

# Google OAuth client (https://console.cloud.google.com). Add your LAN URL
# and the callback path to the authorized redirect URIs. If left blank the
# /auth/google route returns 503 with a hint, the rest of the API still runs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
