# ═══════════════════════════════════════════════════════════════════════════════
#  EXTROPY ENGINE — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Datastore credentials ──────────────────────────────────────────────────
# These are consumed by docker-compose and by the connection-string fallbacks.
# Generate strong values, do NOT ship the dev defaults to any shared or
# production environment. Generate with: openssl rand -hex 24
POSTGRES_USER=extropy
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=extropy_engine
REDIS_PASSWORD=change-me-strong-redis-password

# PostgreSQL connection string. Build it from the credentials above.
# Ports are no longer published to the host by docker-compose; connect through
# the compose network or an explicit tunnel.
DATABASE_URL=postgresql://extropy:change-me-strong-postgres-password@localhost:5432/extropy_engine

# Redis (event bus). Include the password in the URL.
REDIS_URL=redis://:change-me-strong-redis-password@localhost:6379

# Service URLs (for inter-service HTTP calls)
EPISTEMOLOGY_URL=http://localhost:4001
SIGNALFLOW_URL=http://localhost:4002
LOOP_LEDGER_URL=http://localhost:4003
REPUTATION_URL=http://localhost:4004
XP_MINT_URL=http://localhost:4005

# Logging
LOG_LEVEL=debug

# ─── HomeFlow Family Pilot ──────────────────────────────────────────────────
# Used by `pnpm --filter @extropy/homeflow run dev` so the family can sign in
# with Google from their own laptops. See FAMILY_PILOT.md for the full setup.

# Port the homeflow server listens on. Default 4015 in code; the pilot uses
# 4001 so each family member can hit http://<lan-ip>:4001 directly.
PORT=4001

# Public base URL the browser connects to. Used to build the Google OAuth
# callback URL. Set this to your LAN IP plus port for local family use.
BASE_URL=http://localhost:4001

# Sign cookies for the express-session store. Generate with
#   openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Set this to 1 only when serving the pilot over HTTPS, e.g. via Cloudflare
# Tunnel. On HTTP only LAN it must stay unset.
# SECURE_COOKIES=1

# Google OAuth client (https://console.cloud.google.com). Add your LAN URL
# and the callback path to the authorized redirect URIs. If left blank the
# /auth/google route returns 503 with a hint, the rest of the API still runs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Service hardening (required in production) ──────────────────────────────
# NODE_ENV=production turns on fail-closed behavior for the items below.
# NODE_ENV=production

# Temporal callback signing. In production the homeflow temporal routes reject
# unsigned requests unless ALLOW_UNSIGNED_TEMPORAL=1. Generate with openssl rand -hex 32.
TEMPORAL_HMAC_SECRET=
# ALLOW_UNSIGNED_TEMPORAL=1

# Shared secret guarding the interop ingress webhook (POST /interop/events).
INTEROP_INGRESS_SECRET=
# ALLOW_UNSIGNED_INTEROP=1

# API gateway: comma-separated browser origins allowed through CORS, and the
# bearer token required on proxied requests. Both required in production.
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000
GATEWAY_AUTH_TOKEN=

# SignalFlow dashboard origins allowed to open a socket.io connection
# (comma-separated). Required in production.
SIGNALFLOW_DASHBOARD_ORIGINS=http://localhost:3000
