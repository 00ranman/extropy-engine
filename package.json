{
  "name": "extropy-engine",
  "private": true,
  "version": "0.1.0",
  "description": "Civilisational-scale infrastructure where verified entropy reduction is the sole basis of value",
  "author": "Randall Gossett",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "build:contracts": "pnpm --filter @extropy/contracts run build",
    "build:epistemology": "pnpm --filter @extropy/epistemology-engine run build",
    "build:signalflow": "pnpm --filter @extropy/signalflow run build",
    "build:ledger": "pnpm --filter @extropy/loop-ledger run build",
    "build:reputation": "pnpm --filter @extropy/reputation run build",
    "build:mint": "pnpm --filter @extropy/xp-mint run build",
    "build:dag": "pnpm --filter @extropy/dag-substrate run build",
    "build:dfao": "pnpm --filter @extropy/dfao-registry run build",
    "build:governance": "pnpm --filter @extropy/governance run build",
    "build:temporal": "pnpm --filter @extropy/temporal run build",
    "build:temporal-service": "pnpm --filter @extropy/temporal-service run build",
    "start:temporal": "pnpm --filter @extropy/temporal-service start",
    "build:economy": "pnpm --filter @extropy/token-economy run build",
    "build:credentials": "pnpm --filter @extropy/credentials run build",
    "build:ecosystem": "pnpm --filter @extropy/ecosystem run build",
    "build:homeflow": "pnpm --filter @extropy/homeflow run build",
    "build:grantflow-discovery": "pnpm --filter @extropy/grantflow-discovery run build",
    "build:grantflow-proposer": "pnpm --filter @extropy/grantflow-proposer run build",
    "build:identity": "pnpm --filter @extropy/identity run build",
    "build:psll": "pnpm --filter @extropy/psll-sync run build",
    "build:quest-market": "pnpm --filter @extropy/quest-market run build",
    "build:validation-neighborhoods": "pnpm --filter @extropy/validation-neighborhoods run build",
    "build:node-handshake": "pnpm --filter @extropy/node-handshake run build",
    "build:frontends": "pnpm --filter ./frontends/* run build",
    "dev": "docker compose up --build",
    "dev:services": "pnpm -r --if-present --parallel run dev",
    "node-handshake:vps": "NODE_ROLE=vps PORT=4200 pnpm --filter @extropy/node-handshake start",
    "node-handshake:hello": "NODE_ROLE=local pnpm --filter @extropy/node-handshake run client:hello",
    "node-handshake:replay": "NODE_ROLE=local pnpm --filter @extropy/node-handshake run client:replay",
    "test": "pnpm -r --if-present run test",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf packages/*/dist frontends/*/dist"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "tsx": "^4.7.0",
    "vitest": "^2.0.0"
  }
}
