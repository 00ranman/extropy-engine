# build output
node_modules/
dist/

# emitted JS / declarations should never be checked in.
# Keep TS sources only under packages/*/src.
**/*.js
**/*.js.map
**/*.d.ts
**/*.d.ts.map
*.tsbuildinfo

# Whitelist legitimate JS files
!**/scripts/**/*.js
!**/eslint.config.js
!**/jest.config.js
!**/vite.config.js
!**/postcss.config.js
!**/tailwind.config.js

# environment
.env
.env.*
!.env.example

# OS / editors
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# data
pgdata/

# scratch / backups (do NOT commit)
*.bak
*.bak[0-9]
*.bak[0-9][0-9]
*~
*.orig

# pnpm
.pnpm-store/
