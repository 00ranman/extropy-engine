  "description": "Personal Signed Local Log: append-only, hash-chained, signed provenance log per node. Anchored to DAG via Merkle commitments. v3.1.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
