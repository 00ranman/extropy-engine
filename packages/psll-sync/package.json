    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^2.0.0"
  }
}
