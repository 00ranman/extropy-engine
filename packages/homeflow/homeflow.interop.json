{
  "appId": "homeflow",
  "appName": "HomeFlow",
  "version": "1.0.0",
  "description": "IoT-integrated smart home/building management with thermodynamic entropy reduction measurement. Part of the Extropy Engine ecosystem.",
  "port": 4015,
  "healthEndpoint": "/health",
  "eventsEndpoint": "/events",
  "apiBase": "/api/v1",
  "entropyDomains": ["thermodynamic", "economic"],
  "capabilities": [
    "device_management",
    "entropy_measurement",
    "claim_generation",
    "task_validation",
    "cross_domain_aggregation",
    "household_dfao",
    "energy_credits",
    "efficiency_credentials",
    "seasonal_patterns",
    "automation_schedules"
  ],
  "publishedEvents": [
    "homeflow.device.registered",
    "homeflow.device.state_changed",
    "homeflow.device.offline",
    "homeflow.command.issued",
    "homeflow.command.confirmed",
    "homeflow.entropy.snapshot",
    "homeflow.entropy.reduction",
    "homeflow.claim.auto_generated",
    "homeflow.schedule.triggered",
    "homeflow.household.dfao_created",
    "homeflow.token.energy_credit",
    "homeflow.token.household_ct",
    "homeflow.credential.efficiency",
    "homeflow.interop.cross_domain_aggregate",
    "homeflow.temporal.seasonal_pattern",
    "homeflow.task.validation_received",
    "homeflow.task.validation_completed"
  ],
  "subscribedEvents": [
    "epistemology.claim.evaluated",
    "epistemology.claim.submitted",
    "signalflow.task.assigned",
    "signalflow.task.completed",
    "ledger.loop.closed",
    "ledger.loop.failed",
    "ledger.loop.settled",
    "mint.xp.provisional",
    "mint.xp.confirmed",
    "reputation.accrued",
    "temporal.season.started",
    "temporal.season.ended",
    "economy.token.minted",
    "credentials.issued",
    "dfao.created",
    "dag.vertex.created"
  ],
  "apiEndpoints": [
    { "method": "GET",    "path": "/health",                         "description": "Service health check" },
    { "method": "POST",   "path": "/events",                         "description": "Webhook endpoint for incoming events from any service" },
    { "method": "POST",   "path": "/api/v1/households",              "description": "Create a household" },
    { "method": "GET",    "path": "/api/v1/households/:id",          "description": "Get household details" },
    { "method": "PATCH",  "path": "/api/v1/households/:id",          "description": "Update household" },
    { "method": "DELETE", "path": "/api/v1/households/:id",          "description": "Delete household" },
    { "method": "POST",   "path": "/api/v1/zones",                   "description": "Create a zone" },
    { "method": "GET",    "path": "/api/v1/zones/:id",               "description": "Get zone details" },
    { "method": "GET",    "path": "/api/v1/zones?householdId=",      "description": "List zones for household" },
    { "method": "POST",   "path": "/api/v1/devices",                 "description": "Register a device" },
    { "method": "GET",    "path": "/api/v1/devices?householdId=",    "description": "List devices" },
    { "method": "GET",    "path": "/api/v1/devices/:id",             "description": "Get device details" },
    { "method": "PATCH",  "path": "/api/v1/devices/:id",             "description": "Update device" },
    { "method": "DELETE", "path": "/api/v1/devices/:id",             "description": "Delete device" },
    { "method": "POST",   "path": "/api/v1/devices/:id/commands",    "description": "Issue command (e.g. set thermostat to 72°F)" },
    { "method": "GET",    "path": "/api/v1/devices/:id/commands",    "description": "Get command history" },
    { "method": "POST",   "path": "/api/v1/entropy/snapshot",        "description": "Take entropy snapshot" },
    { "method": "POST",   "path": "/api/v1/entropy/measure",         "description": "Measure entropy reduction and auto-generate claim" },
    { "method": "GET",    "path": "/api/v1/entropy/:householdId/history", "description": "Get entropy history" },
    { "method": "GET",    "path": "/api/v1/entropy/claims/:householdId", "description": "Get claims history" },
    { "method": "POST",   "path": "/api/v1/governance/dfao",         "description": "Create household DFAO" },
    { "method": "POST",   "path": "/api/v1/governance/proposals",    "description": "Submit governance proposal" },
    { "method": "POST",   "path": "/api/v1/schedules",               "description": "Create automation schedule" },
    { "method": "GET",    "path": "/api/v1/schedules?householdId=",  "description": "List schedules" },
    { "method": "PATCH",  "path": "/api/v1/schedules/:id/toggle",    "description": "Enable/disable schedule" },
    { "method": "POST",   "path": "/api/v1/schedules/:id/execute",   "description": "Execute schedule" },
    { "method": "DELETE", "path": "/api/v1/schedules/:id",           "description": "Delete schedule" },
    { "method": "GET",    "path": "/api/v1/temporal/patterns?householdId=", "description": "Detect seasonal patterns" },
    { "method": "GET",    "path": "/api/v1/tokens/:householdId",     "description": "Get token balances" },
    { "method": "GET",    "path": "/api/v1/tokens/:householdId/history", "description": "Get token history" },
    { "method": "GET",    "path": "/api/v1/credentials/:householdId", "description": "Get credentials" },
    { "method": "GET",    "path": "/api/v1/reputation/:validatorId", "description": "Get THERMODYNAMIC reputation" },
    { "method": "GET",    "path": "/api/v1/reputation/leaderboard",  "description": "THERMODYNAMIC leaderboard" },
    { "method": "GET",    "path": "/api/v1/dag/:householdId",        "description": "Get DAG vertex references" },
    { "method": "GET",    "path": "/api/v1/interop/manifest",        "description": "Auto-discovery manifest" },
    { "method": "GET",    "path": "/api/v1/interop/adapters",        "description": "List registered adapters" },
    { "method": "POST",   "path": "/api/v1/interop/adapters",        "description": "Register new adapter at runtime" },
    { "method": "GET",    "path": "/api/v1/interop/aggregations?householdId=", "description": "Cross-domain aggregation history" }
  ],
  "crossDomainAggregation": {
    "supported": true,
    "weight": 0.3,
    "formula": "compositeDeltaS = homeflowDeltaS + externalDeltaS * 0.3",
    "description": "HomeFlow energy savings + other domain ΔS values = composite household XP. Cross-domain weight is 0.3 to prevent gaming via domain-hopping."
  },
  "registeredAdapters": [
    { "appId": "academic-xp",          "appName": "AcademicXP",                    "entropyDomains": ["cognitive", "informational"] },
    { "appId": "family-task-planner",   "appName": "AI Family Task Planner",        "entropyDomains": ["social", "economic"] },
    { "appId": "levelup-academy",       "appName": "LevelUp Academy",               "entropyDomains": ["cognitive"] },
    { "appId": "news-buddy",            "appName": "News Buddy",                    "entropyDomains": ["informational"] },
    { "appId": "language-learning",     "appName": "Language Learning",              "entropyDomains": ["cognitive"] },
    { "appId": "global-civ-sim",        "appName": "Global Civilization Simulator",  "entropyDomains": ["governance", "social"] }
  ],
  "integrationGuide": {
    "description": "To integrate a new ecosystem app with HomeFlow:",
    "steps": [
      "1. POST to /api/v1/interop/adapters with { appId, appName, entropyDomains, publishedEvents, subscribedEvents }",
      "2. Send events to POST /events with the standard DomainEvent envelope",
      "3. Include a 'deltaS' field in your payload for cross-domain entropy aggregation",
      "4. Include 'householdId' in event metadata to associate with a HomeFlow household",
      "5. Read the manifest at GET /api/v1/interop/manifest for auto-discovery"
    ]
  }
}
