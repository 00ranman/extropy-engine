{
  "name": "@extropy/node-handshake",
  "version": "0.1.0",
  "description": "Sandbox-to-sandbox node handshake. Lets a VPS-hosted Extropy node and a local laptop node discover, authenticate, exchange capabilities, and replay DAG vertices over a signed channel. Proof-of-concept for v3.1 substrate.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "client:hello": "tsx src/client.ts hello",
    "client:replay": "tsx src/client.ts replay"
  },
  "dependencies": {
    "@extropy/contracts": "*",
    "express": "^4.19.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^2.0.0"
  }
}
